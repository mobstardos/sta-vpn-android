<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="24dp"
    android:paddingTop="10dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/text_first_launch_skip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:alpha="0.58"
        android:background="@drawable/bg_first_launch_badge"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="@font/samsungone"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp"
        android:text="@string/first_launch_skip"
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textColor="#FF16324C"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="18dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="ifContentScrolls">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/text_first_launch_connection_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:fontFamily="@font/samsungsharpsans"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="5dp"
                    android:shadowColor="#3A000000"
                    android:shadowDx="0"
                    android:shadowDy="8"
                    android:shadowRadius="18"
                    android:text="@string/first_launch_connection_title"
                    android:textColor="#FFF9FBFF"
                    android:textSize="38sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_first_launch_connection_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/samsungone"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="4dp"
                    android:shadowColor="#36000000"
                    android:shadowDx="0"
                    android:shadowDy="6"
                    android:shadowRadius="14"
                    android:text="@string/first_launch_connection_description"
                    android:textColor="#EAF9FBFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="0.72" />

                <wings.v.widget.ConnectionChoiceAnimationView
                    android:id="@+id/view_first_launch_connection_animation"
                    android:layout_width="match_parent"
                    android:layout_height="240dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/container_first_launch_connection_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/row_first_launch_connection_import"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_first_launch_paste_clipboard"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_first_launch_inline_button"
                    android:drawableStart="@drawable/ic_clipboard_paste"
                    android:drawablePadding="10dp"
                    android:drawableTint="#FF010102"
                    android:fontFamily="@font/samsungone"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/first_launch_connection_paste_clipboard"
                    android:textColor="#FF010102"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="match_parent" />

                <Button
                    android:id="@+id/button_first_launch_scan_qr"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_first_launch_inline_button"
                    android:drawableStart="@drawable/ic_qr_scan"
                    android:drawablePadding="10dp"
                    android:drawableTint="#FF010102"
                    android:fontFamily="@font/samsungone"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/first_launch_connection_scan_qr"
                    android:textColor="#FF010102"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_first_launch_vk_turn"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_first_launch_inline_button"
                    android:fontFamily="@font/samsungsharpsans"
                    android:text="@string/first_launch_connection_vk_turn"
                    android:textColor="#FF010102"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="match_parent" />

                <Button
                    android:id="@+id/button_first_launch_xray"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_first_launch_inline_button"
                    android:fontFamily="@font/samsungsharpsans"
                    android:text="@string/first_launch_connection_xray"
                    android:textColor="#FF010102"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/button_first_launch_auto_search"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_first_launch_inline_button"
                android:fontFamily="@font/samsungsharpsans"
                android:text="@string/first_launch_connection_auto_search"
                android:textColor="#FF010102"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
