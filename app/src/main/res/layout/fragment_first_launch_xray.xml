<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="24dp"
    android:paddingTop="26dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="ifContentScrolls">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/text_xray_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/samsungsharpsans"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="5dp"
                    android:shadowColor="#3A000000"
                    android:shadowDx="0"
                    android:shadowDy="8"
                    android:shadowRadius="18"
                    android:text="@string/first_launch_xray_title"
                    android:textColor="#FFF9FBFF"
                    android:textSize="36sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_xray_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/samsungone"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="4dp"
                    android:shadowColor="#26000000"
                    android:shadowDx="0"
                    android:shadowDy="6"
                    android:shadowRadius="12"
                    android:text="@string/first_launch_xray_description"
                    android:textColor="#EAF9FBFF"
                    android:textSize="17sp" />

                <LinearLayout
                    android:id="@+id/container_xray_fields"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="22dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:orientation="vertical"
                    android:paddingTop="4dp"
                    android:paddingBottom="12dp" />

            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_first_launch_paste_clipboard"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="@drawable/bg_first_launch_inline_button"
                android:drawableStart="@drawable/ic_clipboard_paste"
                android:drawablePadding="10dp"
                android:drawableTint="#FF010102"
                android:fontFamily="@font/samsungone"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/first_launch_connection_paste_clipboard"
                android:textColor="#FF010102"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="10dp"
                android:layout_height="match_parent" />

            <Button
                android:id="@+id/button_first_launch_scan_qr"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="@drawable/bg_first_launch_inline_button"
                android:drawableStart="@drawable/ic_qr_scan"
                android:drawablePadding="10dp"
                android:drawableTint="#FF010102"
                android:fontFamily="@font/samsungone"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/first_launch_connection_scan_qr"
                android:textColor="#FF010102"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/button_continue_xray"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_first_launch_primary_button"
            android:fontFamily="@font/samsungsharpsans"
            android:text="@string/continue_label"
            android:textColor="#FF010102"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
