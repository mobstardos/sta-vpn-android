<?xml version="1.0" encoding="utf-8"?>
<dev.oneuiproject.oneui.layout.ToolbarLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?roundedCornerColor"
    app:expanded="false"
    app:expandable="false">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingTop="10dp">

            <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:colorBackground"
                android:orientation="vertical"
                android:padding="20dp"
                app:roundedCorners="all">

                <TextView
                    android:id="@+id/text_header_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?android:attr/textAppearanceLarge"
                    android:textColor="?android:textColorPrimary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_header_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="?android:textColorSecondary" />
            </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

            <dev.oneuiproject.oneui.widget.Separator
                android:id="@+id/separator_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sharing_target_settings_section" />

            <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                android:id="@+id/section_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:colorBackground"
                android:orientation="vertical"
                app:roundedCorners="all">

                <dev.oneuiproject.oneui.widget.CardItemView
                    android:id="@+id/row_current_upstreams"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:showTopDivider="false" />

                <dev.oneuiproject.oneui.widget.CardItemView
                    android:id="@+id/row_upstream_interface"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:drawableEnd="@drawable/ic_selected_apps_disclosure" />

                <dev.oneuiproject.oneui.widget.CardItemView
                    android:id="@+id/row_fallback_upstream_interface"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:drawableEnd="@drawable/ic_selected_apps_disclosure" />

                <dev.oneuiproject.oneui.widget.CardItemView
                    android:id="@+id/row_masquerade_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <dev.oneuiproject.oneui.widget.CardItemView
                    android:id="@+id/row_wifi_lock"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <dev.oneuiproject.oneui.widget.SwitchItemView
                    android:id="@+id/row_tether_offload"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <dev.oneuiproject.oneui.widget.SwitchItemView
                    android:id="@+id/item_disable_ipv6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <dev.oneuiproject.oneui.widget.SwitchItemView
                    android:id="@+id/item_dhcp_workaround"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <dev.oneuiproject.oneui.widget.SwitchItemView
                    android:id="@+id/item_repeater_safe_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <dev.oneuiproject.oneui.widget.SwitchItemView
                    android:id="@+id/item_temp_hotspot_use_system"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:showBottomDivider="false" />
            </dev.oneuiproject.oneui.widget.RoundedLinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</dev.oneuiproject.oneui.layout.ToolbarLayout>
