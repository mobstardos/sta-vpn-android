<?xml version="1.0" encoding="utf-8"?>
<dev.oneuiproject.oneui.layout.ToolbarLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?roundedCornerColor"
    app:expanded="false"
    app:expandable="false"
    app:title="@string/vk_oauth_title">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="6dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <dev.oneuiproject.oneui.widget.RoundedLinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?android:colorBackground"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            app:roundedCorners="all">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/vk_oauth_headline"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="?android:textColorPrimary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/vk_oauth_subtitle"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="?android:textColorSecondary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical|start"
                android:orientation="horizontal"
                android:weightSum="1">

                <LinearLayout
                    android:id="@+id/layout_vk_oauth_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_surface_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="7dp">

                    <TextView
                        android:id="@+id/text_vk_oauth_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/vk_oauth_status_loading"
                        android:textColor="?android:textColorPrimary"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/progress_vk_oauth_status"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="8dp"
                        android:indeterminate="true" />
                </LinearLayout>

                <Button
                    android:id="@+id/button_vk_oauth_cancel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:minWidth="0dp"
                    android:text="@string/vk_oauth_cancel" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_vk_oauth_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_surface_card"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/text_vk_oauth_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="?android:textColorPrimary" />

                <Button
                    android:id="@+id/button_vk_oauth_retry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp"
                    android:minWidth="0dp"
                    android:text="@string/vk_oauth_retry" />
            </LinearLayout>
        </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1">

            <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?android:colorBackground"
                android:orientation="vertical"
                android:padding="0dp"
                app:roundedCorners="all">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_surface_card"
                    android:clipChildren="true"
                    android:clipToPadding="true">

                    <FrameLayout
                        android:id="@+id/webview_vk_oauth_container"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </FrameLayout>
            </dev.oneuiproject.oneui.widget.RoundedLinearLayout>
        </FrameLayout>
    </LinearLayout>
</dev.oneuiproject.oneui.layout.ToolbarLayout>
