<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Single scrolling content for the WireGuard / AmneziaWG / VK TURN
             backends, mirroring the Xray ProfilesFragment exactly: the Actions
             (Действия) oneui Separator section and the Profiles list section live
             inside the same NestedScrollView and scroll together. The active-backend
             selector is the FIRST item of the Actions section, followed by the
             add/import profile action.

             For the Xray backend only the Actions section is shown here (the
             Profiles list section is hidden) and the embedded Xray ProfilesFragment,
             which carries its own scrolling list, is mounted in the container below
             and takes the remaining space. -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_simple_profiles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingStart="10dp"
            android:paddingTop="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <dev.oneuiproject.oneui.widget.Separator
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/backend_profiles_actions_section" />

                <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:colorBackground"
                    android:orientation="vertical"
                    app:roundedCorners="all">

                    <dev.oneuiproject.oneui.widget.CardItemView
                        android:id="@+id/row_backend_selector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:drawableEnd="@drawable/ic_selected_apps_disclosure"
                        app:showTopDivider="false"
                        app:showBottomDivider="false" />

                    <androidx.appcompat.widget.AppCompatSpinner
                        android:id="@+id/spinner_backend_top"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:visibility="invisible" />

                    <dev.oneuiproject.oneui.widget.CardItemView
                        android:id="@+id/row_backend_sub_selector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:drawableEnd="@drawable/ic_selected_apps_disclosure"
                        app:showBottomDivider="false" />

                    <androidx.appcompat.widget.AppCompatSpinner
                        android:id="@+id/spinner_backend_sub"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:visibility="invisible" />

                    <dev.oneuiproject.oneui.widget.CardItemView
                        android:id="@+id/row_backend_add_profile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:drawableEnd="@drawable/ic_selected_apps_disclosure"
                        app:showBottomDivider="false" />
                </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

                <LinearLayout
                    android:id="@+id/section_backend_profiles_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <dev.oneuiproject.oneui.widget.Separator
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/xray_profiles_filters_section" />

                    <HorizontalScrollView
                        android:id="@+id/scroll_backend_profile_filters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:fillViewport="false"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/group_backend_profile_filters"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingHorizontal="2dp" />
                    </HorizontalScrollView>

                    <dev.oneuiproject.oneui.widget.Separator
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/backend_profiles_list_section" />

                    <TextView
                        android:id="@+id/text_backend_profiles_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:paddingHorizontal="6dp"
                        android:text="@string/backend_profiles_empty"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:textColor="?android:textColorSecondary"
                        android:visibility="gone" />

                    <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                        android:id="@+id/container_backend_profiles"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="?android:colorBackground"
                        android:orientation="vertical"
                        app:roundedCorners="all" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Host for the existing Xray profiles fragment (Xray backend only). -->
        <FrameLayout
            android:id="@+id/container_xray_profiles"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Multi-select action bar, mirroring the Xray profile list: shown while in
         selection mode (long-press a row -> Select). Top row carries the count +
         select-all + share, bottom row the reset-stats + delete actions. -->
    <dev.oneuiproject.oneui.widget.RoundedLinearLayout
        android:id="@+id/layout_backend_profile_selection_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="12dp"
        android:background="?android:colorBackground"
        android:orientation="vertical"
        android:visibility="gone"
        app:roundedCorners="all">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/text_backend_profile_selection_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="?android:textColorSecondary"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button_backend_profile_select_all"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:text="@string/xray_profiles_select_all_action"
                android:textAllCaps="false" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button_backend_profile_share"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:text="@string/xray_profiles_share_action"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:paddingBottom="6dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button_backend_profile_reset_stats"
                style="?attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/backend_profiles_action_reset_stats"
                android:textAllCaps="false" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button_backend_profile_delete"
                style="?attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/backend_profiles_action_delete"
                android:textAllCaps="false" />
        </LinearLayout>
    </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

</FrameLayout>
