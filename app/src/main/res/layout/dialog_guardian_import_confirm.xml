<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="20dp"
    android:paddingBottom="8dp">

    <FrameLayout
        android:id="@+id/guardian_import_avatar_frame"
        android:layout_width="72dp"
        android:layout_height="72dp">

        <ImageView
            android:id="@+id/guardian_import_avatar_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/guardian_import_avatar_content_description"
            android:scaleType="centerCrop"
            android:src="@drawable/avatar_default" />

        <ProgressBar
            android:id="@+id/guardian_import_avatar_loader"
            style="?android:attr/progressBarStyle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminate="true" />
    </FrameLayout>

    <TextView
        android:id="@+id/guardian_import_username"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="@font/samsungsharpsans_bold"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:textColor="#FFFFFF" />

    <TextView
        android:id="@+id/guardian_import_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textColor="?android:textColorSecondary"
        android:gravity="center" />
</LinearLayout>
