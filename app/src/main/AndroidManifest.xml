            android:launchMode="singleTop"
            android:theme="@style/Theme.STAVPN" />

        <activity
            android:name=".VkAuthBrowserActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:taskAffinity=":vkAuth"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.STAVPN" />

        <activity
            android:name=".WarningConfirmActivity"
            android:exported="false"
