        <service
            android:name=".service.XrayAutoSearchProbeWorker0Service"
            android:exported="false"
            android:process=":autosearch_probe_0" />

        <service
            android:name=".service.XrayAutoSearchProbeWorker1Service"
            android:exported="false"
            android:process=":autosearch_probe_1" />

        <service
            android:name=".service.XrayAutoSearchProbeWorker2Service"
            android:exported="false"
            android:process=":autosearch_probe_2" />

        <service
            android:name=".service.XrayAutoSearchProbeWorker3Service"
