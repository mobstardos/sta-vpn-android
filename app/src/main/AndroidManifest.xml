        <activity
            android:name="dev.oneuiproject.oneui.qr.app.QrScanActivity"
            android:exported="false"
            android:label="@string/qr_scan_title"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:theme="@style/Theme.STAVPN.QrScan" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.STAVPN">
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE_PREFERENCES" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:scheme="stavpn" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:scheme="vless" />
            </intent-filter>

            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="v.wingsnet.org"
                    android:pathPrefix="/open"
                    android:scheme="https" />
                <data
                    android:host="v.wingsnet.org"
                    android:pathPrefix="/open"
                    android:scheme="http" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ExternalActionActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:launchMode="singleTop"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@style/Theme.STAVPN.NoDisplay">
            <intent-filter>
                <action android:name="com.stavpn.android.intent.action.START_TUNNEL" />
                <action android:name="com.stavpn.android.intent.action.STOP_TUNNEL" />
                <action android:name="com.stavpn.android.intent.action.SET_BACKEND" />
                <action android:name="com.stavpn.android.intent.action.SET_BACKEND_XRAY" />
                <action android:name="com.stavpn.android.intent.action.SET_BACKEND_VK" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.ProxyTunnelService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:process=":tunnel">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="vpn_runtime_controller" />
        </service>

        <service
            android:name=".guardian.GuardianService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="guardian_remote_control_channel" />
        </service>

        <activity
            android:name=".guardian.GuardianActivity"
            android:exported="false"
            android:label="@string/guardian_settings_title"
            android:parentActivityName=".MainActivity" />

        <receiver
            android:name=".guardian.GuardianBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <service
            android:name=".service.XrayVpnService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:exported="false"
            android:process=":tunnel">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <service
            android:name="com.wireguard.android.backend.GoBackend$VpnService"
            android:foregroundServiceType="specialUse"
            android:process=":tunnel"
            tools:node="merge">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="userspace_wireguard_vpn" />
        </service>

        <service
            android:name="org.amnezia.awg.backend.GoBackend$VpnService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:process=":tunnel"
            tools:node="merge">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="userspace_amneziawg_vpn" />
        </service>

        <service
            android:name=".service.EmergencyVpnResetService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

