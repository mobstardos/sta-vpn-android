            android:theme="@style/Theme.STAVPN" />

        <activity
            android:name=".XrayProfileEditorActivity"
            android:exported="false"
            android:theme="@style/Theme.STAVPN"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".BackendProfileEditorActivity"
            android:exported="false"
            android:theme="@style/Theme.STAVPN"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".VkTurnProfileEditorActivity"
            android:exported="false"
            android:theme="@style/Theme.STAVPN"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ActiveProbingSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.STAVPN" />

        <activity
            android:name=".AutoSearchActivity"
            android:exported="false"
            android:theme="@style/Theme.STAVPN" />

        <activity
            android:name=".ByeDpiSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.STAVPN" />

        <activity
            android:name=".XposedSettingsActivity"
