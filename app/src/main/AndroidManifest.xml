        <service
            android:name=".service.XrayAutoSearchProbeWorker5Service"
            android:exported="false"
            android:process=":autosearch_probe_5" />

        <service
            android:name=".qs.TunnelQuickSettingsTileService"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true"
            android:icon="@drawable/ic_power"
            android:label="@string/qs_tile_tunnel_label">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".qs.XrayBackendQuickSettingsTileService"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true"
            android:icon="@drawable/ic_profiles"
            android:label="@string/qs_tile_backend_xray_label">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".qs.VkBackendQuickSettingsTileService"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true"
            android:icon="@drawable/ic_sharing_nav"
            android:label="@string/qs_tile_backend_vk_label">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
